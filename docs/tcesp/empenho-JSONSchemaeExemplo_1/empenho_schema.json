{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Edital",
  "description": "JSON schema para o envio de empenhos de contrato.",
  "type": "object",
  "properties": {
    "descritor": {
      "type": "object",
      "properties": {
        "municipio": {
          "$id": "#root/descritor/municipio",
          "title": "Municipio",
          "type": "integer",
          "minimum": 1,
          "maximum": 9999
        },
        "entidade": {
          "$id": "#root/descritor/entidade",
          "title": "Entidade",
          "type": "integer",
          "minimum": 1,
          "maximum": 99999
        },
        "numeroEmpenho": {
          "description": "Número do empenho",
          "type": "string",
          "pattern": "^[1-9][0-9]{0,34}$",
          "maxLength": 35,
          "minLength": 1
        },
        "anoEmpenho": {
          "title": "Ano do empenho",
          "type": "integer",
          "minimum": 1950,
          "maximum": 2100
        },
        "retificacao": {
          "title": "Identifica se o documento é uma retificação; true - Retificação; false - Não é retificação",
          "type": "boolean"
        }
      },
      "required": [
        "municipio",
        "entidade",
		"numeroEmpenho",
		"anoEmpenho",
        "retificacao"
      ],
      "additionalProperties": false
    },
    "codigoContrato": {
      "$id": "#root/codigoContrato",
      "title": "Código único que identifica o ajuste (contrato)",
      "type": "string",
      "maxLength": 30
    },
    "dataEmissaoEmpenho": {
      "title": "Informar a data da emissão do empenho",
      "type": "string",
      "format": "date"
    }
  },
  "required": [
    "descritor",
    "codigoContrato",
    "dataEmissaoEmpenho"
  ],
  "additionalProperties": false
}