   <!-- ======================================================================== -->
   <!-- ======================================================================== -->
   <!-- validação de datas -->
   <!-- ======================================================================== -->
   <!-- define um número decimal válido, que pode ser positivo ou negativo  -->
   <xs:simpleType name="DecimalValido_t">
      <xs:restriction base="xs:decimal">
         <xs:fractionDigits value="2"/>
         <xs:minInclusive value="-9999999999999.00"/>
         <xs:maxInclusive value="9999999999999.00"/>
      </xs:restriction>
   </xs:simpleType>
   <!-- ======================================================================== -->
   <xs:simpleType name="DataValida_t">
      <xs:restriction base="xs:date">
         <xs:minInclusive value="1900-01-01"/>
         <xs:maxInclusive value="2100-12-31"/>
      </xs:restriction>
   </xs:simpleType>
   <!-- ======================================================================== -->
   <!-- define um número decimal positivo maior e igual a 1  -->
   <xs:simpleType name="DecimalPositivo_t">
      <xs:restriction base="xs:decimal">
         <xs:fractionDigits value="2"/>
         <xs:minInclusive value="0.00"/>
         <xs:maxInclusive value="9999999999999.00"/>
      </xs:restriction>
   </xs:simpleType>
   <!-- ======================================================================== -->
   <!-- define um número decimal com três dígitos com valores entre 0.01 e 999.99 -->
   <xs:simpleType name="DecimalPositivoTresDigitos_t">
      <xs:restriction base="xs:decimal">
		 <xs:fractionDigits value="2"/>
         <xs:minInclusive value="0.01"/>
         <xs:maxInclusive value="999.99"/>
      </xs:restriction>
   </xs:simpleType>
   <!-- ======================================================================== -->
   <!-- define um número decimal com quatro dígitos com valores entre 0.01 e 9999.99 -->
   <xs:simpleType name="DecimalPositivoQuatroDigitos_t">
      <xs:restriction base="xs:decimal">
		 <xs:fractionDigits value="2"/>
         <xs:minInclusive value="0.01"/>
         <xs:maxInclusive value="9999.99"/>
      </xs:restriction>
   </xs:simpleType>
   <!-- ======================================================================== -->
   <!-- define um número decimal livre maior ou igual a 0- -->
   <xs:simpleType name="DecimalLivreNaoNegativo_t">
      <xs:restriction base="xs:decimal">
         <xs:minInclusive value="0"/>
      </xs:restriction>
   </xs:simpleType>
   <!-- ======================================================================== -->
   <!-- define um número decimal positivo menor que zero  -->
   <xs:simpleType name="DecimalNegativo_t">
      <xs:restriction base="xs:decimal">
         <xs:fractionDigits value="2"/>
         <xs:maxExclusive value="0.00"/>
         <xs:minInclusive value="-9999999999999.00"/>
      </xs:restriction>
   </xs:simpleType>
   <!-- ======================================================================== -->
   <!-- define um número decimal positivo acima de zero  -->
   <xs:simpleType name="DecimalPositivoMaiorQueZero_t">
      <xs:restriction base="xs:decimal">
         <xs:fractionDigits value="2"/>
         <xs:minInclusive value="0.01"/>
         <xs:maxInclusive value="9999999999999.00"/>
      </xs:restriction>
   </xs:simpleType>
   <!-- ======================================================================== -->
   <!-- define um percentual -->
   <xs:simpleType name="Percentual_t">
      <xs:restriction base="xs:decimal">
         <xs:fractionDigits value="2"/>
         <xs:minInclusive value="0.00"/>
         <xs:maxInclusive value="100.00"/>
      </xs:restriction>
   </xs:simpleType>
   <!-- ======================================================================== -->
   <xs:simpleType name="NatSaldo_t">
      <xs:restriction base="xs:string">
         <xs:enumeration value="D"/>
         <xs:enumeration value="C"/>
      </xs:restriction>
   </xs:simpleType>
